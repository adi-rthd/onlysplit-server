{
  "Backend": {
    "PublicBaseUrl": "https://api-split.onlylabs.in"
  },
  "Jwt": {
    "Issuer": "OnlySplit.API",
    "Audience": "OnlySplit.Clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Razorpay": {
    "Currency": "INR"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://api-split.onlylabs.in"
    ]
  },
  "Database": {
    "RunMigrationsOnStartup": false
  },
  "SeedData": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "api-split.onlylabs.in"
}
